generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PaymentTransaction {
  id         String   @id @default(cuid())
  groupId    String
  memberId   String?
  amountMinor Int
  currency   String
  provider   String
  status     String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
